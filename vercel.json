{
  "version": 2,
  "buildCommand": "npm run build",
  "functions": {
    "server.js": {
      "includeFiles": "cpp/bin/**"
    }
  },
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "server.js"
    },
    {
      "src": "/(.*\\.(?:html|css|js|png|jpg|jpeg|gif|ico|svg|webp))",
      "dest": "public/$1"
    },
    {
      "src": "/(.*)",
      "dest": "public/index.html"
    }
  ]
}
